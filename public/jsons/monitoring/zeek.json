{
    "tool": "zeek",
    "description": "Complete Zeek command and workflow reference from basic to advanced network monitoring and traffic analysis",
    "total_commands": 60,
    "commands": [
        {
            "id": 1,
            "category": "Basic Syntax & Help",
            "command": "zeek -h",
            "example": "zeek -h",
            "explanation": "Displays the command line help summary and available options."
        },
        {
            "id": 2,
            "category": "Basic Syntax & Help",
            "command": "zeek -v",
            "example": "zeek -v",
            "explanation": "Prints the current Zeek version number to verify installation."
        },
        {
            "id": 3,
            "category": "Interface Selection",
            "command": "zeek -i <interface>",
            "example": "zeek -i eth0",
            "explanation": "Starts Zeek in live capture mode listening on the specified network interface."
        },
        {
            "id": 4,
            "category": "Offline Analysis",
            "command": "zeek -r <pcap_file>",
            "example": "zeek -r traffic.pcap",
            "explanation": "Processes a PCAP file offline to generate logs without live capture."
        },
        {
            "id": 5,
            "category": "Offline Analysis",
            "command": "zeek -C -r <pcap_file>",
            "example": "zeek -C -r trace.pcap",
            "explanation": "Analyzes a PCAP file while ignoring invalid IP checksums to prevent dropped packets."
        },
        {
            "id": 6,
            "category": "Configuration",
            "command": "zeek -N",
            "example": "zeek -N",
            "explanation": "Lists all loaded scripts, plugins, and protocol analyzers."
        },
        {
            "id": 7,
            "category": "Policy Management",
            "command": "zeek -i <interface> local",
            "example": "zeek -i eth0 local",
            "explanation": "Runs Zeek on an interface loading the 'local' policy script set for standard monitoring."
        },
        {
            "id": 8,
            "category": "Filtering",
            "command": "zeek -f <bpf_filter> -i <interface>",
            "example": "zeek -f \"tcp port 80\" -i eth0",
            "explanation": "Applies a BPF packet filter to limit analysis to specific traffic only."
        },
        {
            "id": 9,
            "category": "Logging Formats",
            "command": "zeek -r <pcap> LogAscii::use_json=T",
            "example": "zeek -r test.pcap LogAscii::use_json=T",
            "explanation": "Forces all log files to be generated in JSON format instead of TSV."
        },
        {
            "id": 10,
            "category": "File Analysis",
            "command": "zeek -r <pcap> frameworks/files/extract-all-files",
            "example": "zeek -r malware.pcap frameworks/files/extract-all-files",
            "explanation": "Automatically extracts all files seen in the traffic to the disk."
        },
        {
            "id": 11,
            "category": "File Analysis",
            "command": "zeek -r <pcap> frameworks/files/hash-all-files",
            "example": "zeek -r transfer.pcap frameworks/files/hash-all-files",
            "explanation": "Calculates MD5 and SHA1 hashes for all transferred files and adds them to files.log."
        },
        {
            "id": 12,
            "category": "Signature Matching",
            "command": "zeek -s <signature_file> -r <pcap>",
