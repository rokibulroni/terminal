{
    "tool": "exiftool",
    "description": "Complete ExifTool command and workflow reference from basic to advanced metadata analysis and manipulation",
    "total_commands": 60,
    "commands": [
        {
            "id": 1,
            "category": "Basic ExifTool Syntax",
            "command": "exiftool -ver",
            "example": "exiftool -ver",
            "explanation": "Displays the installed version number of the ExifTool application"
        },
        {
            "id": 2,
            "category": "Basic Metadata Inspection",
            "command": "exiftool <file>",
            "example": "exiftool evidence.jpg",
            "explanation": "Extracts and displays all standard metadata tags found in the specified file"
        },
        {
            "id": 3,
            "category": "Basic Metadata Inspection",
            "command": "exiftool -a <file>",
            "example": "exiftool -a document.pdf",
            "explanation": "Displays all metadata tags, including duplicate tags that are normally suppressed"
        },
        {
            "id": 4,
            "category": "Output and Formatting Control",
            "command": "exiftool -s <file>",
            "example": "exiftool -s image.png",
