{
    "tool": "rpcclient",
    "description": "Complete rpcclient command reference covering all options from basic to advanced",
    "total_commands": 100,
    "commands": [
        {
            "id": 1,
            "category": "Basic Connection",
            "command": "rpcclient -U \"\" 192.168.1.10",
            "example": "rpcclient -U \"\" 192.168.1.10",
            "explanation": "Connects to the target RPC service using a null session without authentication."
        },
        {
            "id": 2,
            "category": "Basic Connection",
            "command": "rpcclient -U \"\" -N 192.168.1.10",
            "example": "rpcclient -U \"\" -N 192.168.1.10",
            "explanation": "Connects using a null session and explicitly suppresses the password prompt."
        },
        {
            "id": 3,
            "category": "Basic Connection",
            "command": "rpcclient -U \"%\" 192.168.1.10",
            "example": "rpcclient -U \"%\" 192.168.1.10",
            "explanation": "Attempts to connect with a blank username and blank password shorthand."
        },
        {
            "id": 4,
            "category": "Basic Connection",
            "command": "rpcclient -U \"user\" 192.168.1.10",
            "example": "rpcclient -U \"administrator\" 192.168.1.10",
            "explanation": "Connects specifying a username and prompts interactively for the password."
        },
        {
            "id": 5,
            "category": "Basic Connection",
            "command": "rpcclient -U \"user%password\" 192.168.1.10",
            "example": "rpcclient -U \"admin%Password123\" 192.168.1.10",
            "explanation": "Connects using a username and password provided inline for automation."
        },
        {
            "id": 6,
            "category": "Authentication",
            "command": "rpcclient -W WORKGROUP -U \"user%pass\" 192.168.1.10",
            "example": "rpcclient -W CORP -U \"jsmith%Summer2023\" 10.10.10.5",
            "explanation": "Authenticates to a specific workgroup or domain controller."
        },
        {
            "id": 7,
            "category": "Authentication",
            "command": "rpcclient -k 192.168.1.10",
            "example": "rpcclient -k dc.example.local",
            "explanation": "Uses Kerberos authentication instead of NTLM (requires valid ticket)."
        },
        {
            "id": 8,
            "category": "Authentication",
            "command": "rpcclient --pw-nt-hash \"hash\" -U \"user\" 192.168.1.10",
            "example": "rpcclient --pw-nt-hash \"aad3b435b51404eeaad3b435b51404ee:8846f7eaee8fb117ad06bdd830b7586c\" -U \"Administrator\" 192.168.1.10",
            "explanation": "Performs a Pass-the-Hash attack by authenticating with an NT hash."
        },
        {
            "id": 9,
            "category": "Transport Configuration",
            "command": "rpcclient -I 192.168.1.10 target_netbios_name",
            "example": "rpcclient -I 192.168.1.10 FILESERVER01",
            "explanation": "Forces the destination IP address while resolving a specific NetBIOS name."
        },
        {
            "id": 10,
            "category": "Transport Configuration",
            "command": "rpcclient -p 445 192.168.1.10",
            "example": "rpcclient -p 445 192.168.1.10",
            "explanation": "Connects explicitly over SMB port 445 (TCP)."
        },
        {
            "id": 11,
            "category": "Transport Configuration",
            "command": "rpcclient -p 139 192.168.1.10",
            "example": "rpcclient -p 139 192.168.1.10",
            "explanation": "Connects explicitly over NetBIOS Session port 139 (TCP)."
        },
        {
            "id": 12,
            "category": "Security Options",
            "command": "rpcclient -S on 192.168.1.10",
            "example": "rpcclient -S on 192.168.1.10",
            "explanation": "Enforces SMB signing state to 'on' for the connection."
        },
        {
            "id": 13,
            "category": "Security Options",
            "command": "rpcclient -P 192.168.1.10",
            "example": "rpcclient -P 192.168.1.10",
            "explanation": "Requests SMB sealing (encryption) for the connection."
        },
        {
